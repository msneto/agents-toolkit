#!/usr/bin/env bun
import { spawnSync } from 'child_process';
import path from 'path';

const currentFile = import.meta.url.replace('file://', '');
const root = path.join(path.dirname(currentFile), '..');

const result = spawnSync('bun', ['run', path.join(root, 'src/index.ts'), ...process.argv.slice(2)], {
  stdio: 'inherit',
});

process.exit(result.status ?? 0);
